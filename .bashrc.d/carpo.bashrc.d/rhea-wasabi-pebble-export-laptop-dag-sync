#!/usr/bin/env bash
set -u
_shutdown_requested=0
_active_pipeline=
_active_pipeline_pgid=
_wait_child=
_retry_sleep_pid=
_signal_exit_status=143

log() { printf '%s - %s\n' "$(date)" "$*" >&2; }

terminate_active_pipeline() {
    local grace="${IPFS_DAG_EXPORT_TERMINATE_TIMEOUT:-5}"
    local deadline
    local now

    _shutdown_requested=1

    if [[ -z "${_active_pipeline_pgid:-}" ]]; then
        return 0
    fi

    log "Sending SIGTERM to export pipeline process group ${_active_pipeline_pgid}"
    kill -TERM -- "-${_active_pipeline_pgid}" 2>/dev/null || true

    deadline=$(python3 -c 'import sys,time
try:
    grace=float(sys.argv[1])
except ValueError:
    grace=5.0
if grace < 0:
    grace=5.0
print(time.monotonic() + grace)' "$grace" 2>/dev/null || echo "$((SECONDS + 5))")
    while kill -0 -- "-${_active_pipeline_pgid}" 2>/dev/null
    do
        now=$(python3 -c 'import time; print(time.monotonic())' 2>/dev/null || echo "$SECONDS")
        python3 -c 'import sys; raise SystemExit(0 if float(sys.argv[1]) >= float(sys.argv[2]) else 1)' "$now" "$deadline" && break
        sleep 0.1 9>&-
    done

    if kill -0 -- "-${_active_pipeline_pgid}" 2>/dev/null
    then
        log "Grace period expired for export pipeline process group ${_active_pipeline_pgid}"
        log "Sending SIGKILL to export pipeline process group ${_active_pipeline_pgid}"
        kill -KILL -- "-${_active_pipeline_pgid}" 2>/dev/null || true
    fi

    if [[ -n "${_active_pipeline:-}" ]]
    then
        wait "$_active_pipeline" 2>/dev/null || true
    fi

    log "Export pipeline cleanup completed"
    _active_pipeline=
    _active_pipeline_pgid=
}

request_shutdown() {
    local status=$1
    _shutdown_requested=1
    _signal_exit_status=$status

    if [[ -n "${_wait_child:-}" ]]; then
        kill "$_wait_child" 2>/dev/null || true
    fi
    if [[ -n "${_retry_sleep_pid:-}" ]]; then
        kill "$_retry_sleep_pid" 2>/dev/null || true
    fi
    if [[ -n "${_active_pipeline_pgid:-}" ]]; then
        log "Sending SIGTERM to export pipeline process group ${_active_pipeline_pgid}"
        kill -TERM -- "-${_active_pipeline_pgid}" 2>/dev/null || true
    elif [[ -n "${_active_pipeline:-}" ]]; then
        kill -TERM "$_active_pipeline" 2>/dev/null || true
    fi
}

shutdown_trap() {
    request_shutdown "$1"
}
trap 'shutdown_trap 130' INT
trap 'shutdown_trap 143' TERM

interruptible_sleep() {
    local duration=$1
    sleep "$duration" 9>&- &
    _retry_sleep_pid=$!
    wait "$_retry_sleep_pid" 2>/dev/null
    local status=$?
    _retry_sleep_pid=
    if (( _shutdown_requested != 0 )); then
        return "$_signal_exit_status"
    fi
    return "$status"
}

acquire_export_lock() {
    local poll_interval="${IPFS_DAG_EXPORT_LOCK_POLL_INTERVAL:-0.1}"
    local lock_acquired=0

    while (( _shutdown_requested == 0 ))
    do
        if flock -n 9
        then
            lock_acquired=1
            break
        fi

        sleep "$poll_interval" 9>&- &
        _wait_child=$!
        wait "$_wait_child" 2>/dev/null || true
        _wait_child=
    done

    (( lock_acquired == 1 )) || return "$_signal_exit_status"
    return 0
}

rhea_wasabi_pebble_export_laptop_dag_pipeline() {
    local cid=$1
    local laptop_socket="${IPFS_LAPTOP_API_SOCKET:-${HOME}/.var/run/ipfs-laptop-api.sock}"
    local rhea_socket="${RHEA_IPFS_WASABI_SOCKET:-${HOME}/.var/run/rhea-ipfs-wasabi.sock}"
    local source_image="${LAPTOP_IPFS_CLI_IMAGE:-ipfs/go-ipfs:v0.8.0}"
    local destination_image="${RHEA_IPFS_CLI_IMAGE:-ipfs/go-ipfs:v0.31.0}"

    command -v docker >/dev/null 2>&1 || { echo "docker is not installed or not in PATH" >&2; return 1; }
    command -v mbuffer >/dev/null 2>&1 || { echo "mbuffer is not installed or not in PATH" >&2; return 1; }

    set -o pipefail
    docker run --rm --log-driver none \
        --mount "type=bind,src=${laptop_socket},dst=/run/ipfs-laptop-api.sock" \
        --entrypoint /usr/local/bin/ipfs \
        "$source_image" \
        --api=/unix/run/ipfs-laptop-api.sock \
        dag export --progress=false "$cid" \
    | mbuffer -e \
    | docker run --rm -i --log-driver none \
        --mount "type=bind,src=${rhea_socket},dst=/run/rhea-ipfs-wasabi.sock" \
        --entrypoint /usr/local/bin/ipfs \
        "$destination_image" \
        --api=/unix/run/rhea-ipfs-wasabi.sock \
        dag import --pin-roots=false --allow-big-block
}

run_active_export_attempt() {
    local cid=$1
    local script_path=${BASH_SOURCE[0]}
    if [[ -n "${IPFS_DAG_EXPORT_SYNC_HOOK:-}" ]]; then
        setsid -- "$IPFS_DAG_EXPORT_SYNC_HOOK" "$cid" 9>&- &
    else
        setsid -- bash -c 'exec 9>&-; source "$1"; trap - INT TERM; rhea_wasabi_pebble_export_laptop_dag_pipeline "$2"' bash "$script_path" "$cid" &
    fi
    _active_pipeline=$!
    _active_pipeline_pgid="$(ps -o pgid= -p "$_active_pipeline" 2>/dev/null | tr -d '[:space:]')"
    if [[ -z "$_active_pipeline_pgid" ]]; then
        _active_pipeline_pgid=$_active_pipeline
    fi
    wait "$_active_pipeline"
    local status=$?
    if (( _shutdown_requested != 0 )); then
        terminate_active_pipeline
        return "$_signal_exit_status"
    fi
    _active_pipeline=
    _active_pipeline_pgid=
    return "$status"
}

rhea_wasabi_pebble_export_laptop_dag_sync() {
    if [[ $# -ne 1 || -z "${1:-}" ]]; then
        echo "usage: rhea-wasabi-pebble-export-laptop-dag-sync <cid>" >&2
        return 2
    fi
    command -v flock >/dev/null 2>&1 || { echo "flock is not installed or not in PATH" >&2; return 1; }
    command -v setsid >/dev/null 2>&1 || { echo "setsid is not installed or not in PATH" >&2; return 1; }
    local cid=$1
    local lock="${IPFS_DAG_EXPORT_LOCK:-${HOME}/.var/run/rhea-wasabi-pebble-export-laptop-dag.lock}"
    local retry_delay="${IPFS_DAG_RETRY_DELAY:-300}"
    mkdir -p -- "$(dirname -- "$lock")" || return 1

    exec 9>"$lock" || return 1
    acquire_export_lock || return "$_signal_exit_status"

    while (( _shutdown_requested == 0 )); do
        log "Exporting ${cid} from laptop and importing to rhea"
        run_active_export_attempt "$cid"
        local status=$?
        if (( _shutdown_requested != 0 )); then
            return "$status"
        fi
        if (( status == 0 )); then
            log "Done ${cid}"
            return 0
        fi
        log "Failed ${cid}; retrying in ${retry_delay} seconds"
        interruptible_sleep "$retry_delay" || return "$_signal_exit_status"
    done
    return "$_signal_exit_status"
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
    rhea_wasabi_pebble_export_laptop_dag_sync "$@"
fi
