#!/bin/bash

function _curl () {
    curl --silent "${@}"
    echo
}

function curljson () {
    _curl  -H "Content-Type: application/json" "${@}"
}

function curljsonp () {
    _curl  -X POST -H "Content-Type: application/json" "${@}"
}

function rawurlencode () {
  local string="${1}"
  local strlen=${#string}
  local encoded=""
  local pos c o

  for (( pos=0 ; pos<strlen ; pos++ )); do
     c=${string:$pos:1}
     case "$c" in
        [-_.~a-zA-Z0-9] ) o="${c}" ;;
        * )               printf -v o '%%%02x' "'$c"
     esac
     encoded+="${o}"
  done
  echo "${encoded}"
}

function orbitdb-open () {
    local host
    local dbAddr

    host=${2:-"https://orbitdb-api.phillm.net:3000"}

    dbAddr=$(rawurlencode "${1}")

    curljsonp -d '{"awaitOpen": false}' "${host}/db/${dbAddr}"
}

function orbitdb-close () {
    local host
    local dbAddr

    host=${2:-"https://orbitdb-api.phillm.net:3000"}

    dbAddr=$(rawurlencode "${1}")

    curl -X DELETE "${host}/db/${dbAddr}"
}

function orbitdb-pending () {
    local dbAddr

    host=${1:-"https://orbitdb-api.phillm.net:3000"}

    dbAddr=$(rawurlencode "${1}")

    curl "${host}/db/pending"
}

function ipfs() {
    if [[ "$(docker network ls --format '{{.Name}}')" == *"phill-dev_ipfs"* ]]; then
        docker run --rm -v "$(pwd)":/tmp -w /tmp --net phill-dev_ipfs peelvalley/ipfs-cli "${@}"
    else
        docker run --rm -v "$(pwd)":/tmp -w /tmp --net pvs-dev_ipfs peelvalley/ipfs-cli "${@}"
    fi

}


function ipfs_add_folder() {
    local file
    local folder
    local file_hash

    file="${1}"
    folder="${2}"

    file_hash=$(ipfs add --pin=false -Q "${file}")

    ipfs files cp "/ipfs/${file_hash}" "/${folder}/${file}"

}

function youtube_dl () {
    docker run --rm -v /callisto/Data:/workdir -w/workdir python bash -c "apt update && apt install ffmpeg -y && pip install youtube-dl && youtube-dl ${*}"
}

function nodejs_dev () {
    docker run --rm -it -w /wd   -v "$(pwd)":/wd node:latest bash -c "${*}"
}

function video_archive () {
    docker run --rm -v /root:/root -v /callisto/Data/Upload/TV-Shows:/TV-Shows peelvalley/rclone-b2 "rclone move --verbose --transfers 1 /TV-Shows  b2-phill:Video-Archive2/TV-Shows"
    docker run --rm -v /root:/root -v /callisto/Data/Upload/Movies:/Movies peelvalley/rclone-b2 "rclone move --verbose --transfers 1 --delete-empty-src-dirs /Movies  b2-phill:Video-Archive2/Movies"
}

export -f ipfs
export -f ipfs_add_folder
export -f video_archive

