#!/bin/bash


[[ "${HOSTENV_DEBUG}" ]] && {
    echo "Searching for ${BASH_RC_HOST_DIR}" >&2
}
[[ -d "${BASH_RC_HOST_DIR}" ]] && {
    [[ "${HOSTENV_DEBUG}" ]] && {
    echo "Found ${BASH_RC_HOST_DIR}" >&2
    }
    for file in "${BASH_RC_HOST_DIR}"/*
    do
        [[ "${HOSTENV_DEBUG}" ]] && {
                echo "Sourcing ${file}"
        }
        source "${file}"
    done
}


