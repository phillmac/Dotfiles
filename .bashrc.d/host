#!/bin/bash
shorthost=$(cut -d"." -f1 <<<"$HOSTNAME")
bashrcdir="${HOME}/.bashrc.d/${shorthost}.bashrc.d"

[[ "${HOSTENV_DEBUG}" ]] && {
    echo "Searching for ${bashrcdir}" >&2
}
[[ -d "${bashrcdir}" ]] && {
    [[ "${HOSTENV_DEBUG}" ]] && {
    echo "Found ${bashrcdir}" >&2
    }
    for file in "${bashrcdir}"/*
    do
        [[ "${HOSTENV_DEBUG}" ]] && {
                echo "Sourcing ${file}"
        }
        source "${file}"
    done
}