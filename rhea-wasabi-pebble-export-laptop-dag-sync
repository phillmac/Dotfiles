#!/usr/bin/env bash
set -u

log() { printf '%s - %s\n' "$(date)" "$*" >&2; }

rhea_wasabi_pebble_export_laptop_dag_pipeline() {
    local cid=$1
    local laptop_socket="${IPFS_LAPTOP_API_SOCKET:-${HOME}/.var/run/ipfs-laptop-api.sock}"
    local rhea_socket="${RHEA_IPFS_WASABI_SOCKET:-${HOME}/.var/run/rhea-ipfs-wasabi.sock}"
    local source_image="${LAPTOP_IPFS_CLI_IMAGE:-ipfs/go-ipfs:v0.8.0}"
    local destination_image="${RHEA_IPFS_CLI_IMAGE:-ipfs/go-ipfs:v0.31.0}"
    local retry_delay="${IPFS_DAG_RETRY_DELAY:-300}"

    command -v docker >/dev/null 2>&1 || { echo "docker is not installed or not in PATH" >&2; return 1; }
    command -v mbuffer >/dev/null 2>&1 || { echo "mbuffer is not installed or not in PATH" >&2; return 1; }

    while true; do
        if [[ ! -S "$laptop_socket" ]]; then
            log "Laptop IPFS socket is unavailable: ${laptop_socket}; retrying ${cid} in ${retry_delay} seconds"
            sleep "$retry_delay"
            continue
        fi
        if [[ ! -S "$rhea_socket" ]]; then
            log "Rhea IPFS socket is unavailable: ${rhea_socket}; retrying ${cid} in ${retry_delay} seconds"
            sleep "$retry_delay"
            continue
        fi

        log "Exporting ${cid} from laptop and importing to rhea"
        if ( set -o pipefail
            docker run --rm --log-driver none \
                --mount "type=bind,src=${laptop_socket},dst=/run/ipfs-laptop-api.sock" \
                --entrypoint /usr/local/bin/ipfs \
                "$source_image" \
                --api=/unix/run/ipfs-laptop-api.sock \
                dag export --progress=false "$cid" \
            | mbuffer -e \
            | docker run --rm -i --log-driver none \
                --mount "type=bind,src=${rhea_socket},dst=/run/rhea-ipfs-wasabi.sock" \
                --entrypoint /usr/local/bin/ipfs \
                "$destination_image" \
                --api=/unix/run/rhea-ipfs-wasabi.sock \
                dag import --pin-roots=false --allow-big-block
        ); then
            log "Done ${cid}"
            return 0
        fi
        log "Failed ${cid}; retrying in ${retry_delay} seconds"
        sleep "$retry_delay"
    done
}

rhea_wasabi_pebble_export_laptop_dag_sync() {
    if [[ $# -ne 1 || -z "${1:-}" ]]; then
        echo "usage: rhea-wasabi-pebble-export-laptop-dag-sync <cid>" >&2
        return 2
    fi
    command -v flock >/dev/null 2>&1 || { echo "flock is not installed or not in PATH" >&2; return 1; }
    local lock="${IPFS_DAG_EXPORT_LOCK:-${HOME}/.var/run/rhea-wasabi-pebble-export-laptop-dag.lock}"
    mkdir -p -- "$(dirname -- "$lock")" || return 1
    (
        flock -x 9 || exit 1
        if [[ -n "${IPFS_DAG_EXPORT_SYNC_HOOK:-}" ]]; then
            "$IPFS_DAG_EXPORT_SYNC_HOOK" "$1"
        else
            rhea_wasabi_pebble_export_laptop_dag_pipeline "$1"
        fi
    ) 9>"$lock"
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
    rhea_wasabi_pebble_export_laptop_dag_sync "$@"
fi
